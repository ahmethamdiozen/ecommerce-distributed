generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OrderEvent {
  id        Int      @id @default(autoincrement())
  orderId   String   @unique
  userId    String
  productId String
  quantity  Int
  eventType String
  createdAt DateTime @default(now())

  @@map("order_events")
}
