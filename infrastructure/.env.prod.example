# Shared Postgres (single Coolify instance, separate DBs per service group)
# order-service + inventory-service share the OrderEvent table — same DB.
# Create these databases manually in the shared postgres once:
#   CREATE DATABASE ecommerce_auth;
#   CREATE DATABASE ecommerce_events;
AUTH_DATABASE_URL=postgresql://USER:PASSWORD@shared-postgres:5432/ecommerce_auth
ORDER_DATABASE_URL=postgresql://USER:PASSWORD@shared-postgres:5432/ecommerce_events
INVENTORY_DATABASE_URL=postgresql://USER:PASSWORD@shared-postgres:5432/ecommerce_events

# Shared Redis
REDIS_URL=redis://shared-redis:6379
REDIS_HOST=shared-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ (internal to this stack)
RABBITMQ_USER=admin
RABBITMQ_PASS=change-me-strong

# JWT secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
