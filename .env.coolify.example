# PostgreSQL
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me-strong

# Redis (bos birakilabilir, sifresiz calisir)
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=change-me-strong

# JWT (openssl rand -hex 32 ile uret)
JWT_ACCESS_SECRET=change-me-32-char-random-string
JWT_REFRESH_SECRET=change-me-32-char-random-string

# Admin hesaplari (kayit olunca admin rolü verilecek e-postalar)
ADMIN_EMAILS=admin@yourdomain.com

# MinIO (object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_BUCKET=products
# MinIO'nun public URL'i - Coolify'da MinIO servisine atanan domain
MINIO_PUBLIC_URL=https://minio.yourdomain.com

# Frontend build-time API URL'leri
# Coolify'da frontend servisine atanan domain üzerinden nginx proxy kullanıyoruz,
# bu yüzden bu değerler genellikle bos kalir (nginx.conf proxy_pass ile hallediliyor)
VITE_AUTH_URL=
VITE_ORDER_URL=
VITE_INVENTORY_URL=

# Frontend portu (Coolify reverse proxy arkasinda 80 kullanilir)
FRONTEND_PORT=80
